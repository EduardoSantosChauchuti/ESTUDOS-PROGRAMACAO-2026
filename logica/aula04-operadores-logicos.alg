algoritmo "Primeiro"
//Disciplina: Lógica da programacao
//Professor: Gustavo Guanabara
//Descricao: Aprendendo a comparar valor
var
   A, B, C: inteiro
inicio
      A <- 7
      B <- 3
      C <- 1
      Escreva ((A=B) ou (C<A))// vai mostrar verdadeiro
      Escreva ((A=B) e  (C<A))// vai mostrar falso
      Escreva (nao((A=B) ou (C<A)))// vai mostrar falso
fimalgoritmo
