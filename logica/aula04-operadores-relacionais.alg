algoritmo "Primeiro"
//Disciplina: Lógica da programacao
//Professor: Gustavo Guanabara
//Descricao: Aprendendo a comparar valor
var
   A, B, C: inteiro
inicio
      A <- 7
      B <- 3
      C <- 1
      Escreva (A>B)// vai mostrar verdadeiro
      Escreva (A<B)// vai mostrar falso
      Escreva (C= A+B)// vai mostrar falso
fimalgoritmo
